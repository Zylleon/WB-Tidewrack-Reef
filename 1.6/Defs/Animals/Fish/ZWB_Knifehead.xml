<?xml version="1.0" encoding="utf-8"?>
<Defs>



	<ThingDef ParentName="AnimalThingBase">
		<defName>ZWB_Knifehead</defName>
		<label>knifehead</label>
		<description>A small predatory fish, adapted for land. It is named for its distinctive, crest-like fin.</description>
		<statBases>
			<MoveSpeed>4.2</MoveSpeed>
			<ComfyTemperatureMin>-5</ComfyTemperatureMin>
			<ComfyTemperatureMax>45</ComfyTemperatureMax>
			<MarketValue>120</MarketValue>
			<Wildness>0.3</Wildness>
		</statBases>
		<comps>
			<li Class="CompProperties_EggLayer">
				<eggUnfertilizedDef>ZWB_EggKnifeheadUnfertilized</eggUnfertilizedDef>	
				<eggFertilizedDef>ZWB_EggKnifeheadFertilized</eggFertilizedDef>
				<eggFertilizationCountMax>1</eggFertilizationCountMax>
				<eggLayIntervalDays>4</eggLayIntervalDays>
				<eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
				<eggCountRange>1~2</eggCountRange>
			</li>
		</comps>
		<race>
			<body>ZWB_BipedLandFish</body>
			<herdAnimal>false</herdAnimal>
			<!-- <maxPreyBodySize>0.99</maxPreyBodySize> -->
			<baseBodySize>0.4</baseBodySize>
			<baseHungerRate>0.18</baseHungerRate>
			<baseHealthScale>0.65</baseHealthScale>
			<foodType>OmnivoreAnimal</foodType>
			<leatherDef>ZWB_Leather_Fishskin</leatherDef>
			<trainability>None</trainability>
			<useMeatFrom>ZWB_Jesterfish</useMeatFrom>
			<lifeExpectancy>6</lifeExpectancy>
			<manhunterOnTameFailChance>0.2</manhunterOnTameFailChance>
			<manhunterOnDamageChance>0.2</manhunterOnDamageChance>
			
			<lifeStageAges>
				<li>
					<def>AnimalBaby</def>
					<minAge>0</minAge>
				</li>
				<li>
					<def>AnimalJuvenile</def>
					<minAge>0.12</minAge>
				</li>
				<li>
					<def>AnimalAdult</def>
					<minAge>0.24</minAge>
					<soundWounded>ZWB_SmallFish_Wounded</soundWounded>
					<soundDeath>ZWB_SmallFish_Death</soundDeath>
					<soundCall>ZWB_SmallFish_Call</soundCall>
					<soundAngry>ZWB_SmallFish_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
			<soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
			<soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
			<soundEating>PredatorSmall_Eat</soundEating>
			<packAnimal>false</packAnimal>
			<predator>true</predator>
			<!-- <headPosPerRotation> -->
			<!-- <li>(0.0, 0, 0.09)</li> -->
			<!-- <li>(0.28, 0, 0)</li> -->
			<!-- <li>(0.0, 0, -0.04)</li> -->
			<!-- <li>(-0.28, 0, 0)</li> -->
			<!-- </headPosPerRotation> -->
		</race>
		<tradeTags>
			<li>AnimalUncommon</li>
		</tradeTags>
		<tools>
			<li>
				<capacities>
					<li>Bite</li>
				</capacities>
				<power>10</power>
				<cooldownTime>1.9</cooldownTime>
				<linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
				<chanceFactor>0.7</chanceFactor>
			</li>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<chanceFactor>0.2</chanceFactor>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>10</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>left flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>4.5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontLeftFlipper</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>8</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
			<li>
				<label>right flipper</label>
				<labelNoLocation>flipper</labelNoLocation>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>4.5</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>ZWB_FrontRightFlipper</linkedBodyPartsGroup>
				<surpriseAttack>
					<extraMeleeDamages>
						<li>
							<def>Stun</def>
							<amount>8</amount>
						</li>
					</extraMeleeDamages>
				</surpriseAttack>
			</li>
		</tools>
	</ThingDef>


