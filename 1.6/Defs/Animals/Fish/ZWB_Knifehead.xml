	<ThingDef ParentName="EggFertBase">
		<defName>ZWB_EggKnifeheadFertilized</defName>
		<label>knifehead egg (fert.)</label>
		<description>A fertilized knifehead egg. If all goes well, it should hatch into a baby knifehead. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggOval</texPath>
			<color>(217,101,72)</color>
			<drawSize>0.7</drawSize>
		</graphicData>
		<statBases>
			<Nutrition>0.5</Nutrition>
			<MarketValue>18.0</MarketValue>
		</statBases>
		<comps>
			<li Class="CompProperties_Hatcher">
				<hatcherDaystoHatch>7</hatcherDaystoHatch>
				<hatcherPawn>ZWB_Knifehead</hatcherPawn>
			</li>
		</comps>
	</ThingDef>



	<ThingDef ParentName="EggUnfertBase">
		<defName>ZWB_EggKnifeheadUnfertilized</defName>
		<label>spotted shoobler egg (unfert.)</label>
		<description>An unfertilized spotted shoobler egg. It can be eaten raw, but it's much better cooked.</description>
		<graphicData>
			<texPath>Things/Item/Resource/AnimalProductRaw/EggOval</texPath>
			<color>(168,102,86)</color>
			<drawSize>0.7</drawSize>
		</graphicData>
		<statBases>
			<MarketValue>11.0</MarketValue>
			<Nutrition>0.5</Nutrition>
		</statBases>
	</ThingDef>




</Defs>

