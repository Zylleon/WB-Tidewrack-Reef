<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<GenStepDef>
		<order>960</order>
		<defName>ZWB_GenstepScatterSeashells</defName>
		<genStep Class="GenStep_ScatterGroup">
			<allowInWaterBiome>true</allowInWaterBiome>
			<minSpacing>25</minSpacing>
			<countPer10kCellsRange>0.35~1.1</countPer10kCellsRange>

			<validators>
				<li Class="ScattererValidator_Buildable">
					<radius>2</radius>
					<affordance>Medium</affordance>
				</li>
			</validators>
			<groups>
				<li>
					<things>
						<ZWB_SeashellGiant>1</ZWB_SeashellGiant>
						<ZWB_SeashellSmall>3</ZWB_SeashellSmall>
					</things>
					<coveredCellsPer10Cells>0.1~0.7</coveredCellsPer10Cells>
					<clusterRectRadius>10~17</clusterRectRadius>
				</li>
			</groups>
		</genStep>
	</GenStepDef>


	<ThingDef ParentName="AncientBuildingBase">
		<defName>ZWB_SeashellGiant</defName>
		<label>calcified seashell</label>
		<description>A giant calcified seashell.</description>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>12</Beauty>
			<WorkToBuild>24000</WorkToBuild>
		</statBases>
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<graphicData>
			<texPath>ZWB_Textures/Things/SeashellGiant</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>3.0</drawSize>
			<shadowData>
				<volume>(0.7,0.3,1.2)</volume>
			</shadowData>
			<drawRotated>false</drawRotated>
		</graphicData>
		<size>(2,2)</size>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<killedLeavings>
			<ChunkLimestone>3</ChunkLimestone>
		</killedLeavings>
		<costList>
			<ChunkLimestone>10</ChunkLimestone>
		</costList>
	</ThingDef>



	<ThingDef ParentName="AncientBuildingBase">
		<defName>ZWB_SeashellSmall</defName>
		<label>calcified seashell</label>
		<description>A giant calcified seashell.</description>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>4</Beauty>
			<WorkToBuild>8000</WorkToBuild>
		</statBases>
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<graphicData>
			<texPath>ZWB_Textures/Things/SeashellSmall</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>1.0</drawSize>
			<drawRotated>false</drawRotated>
			<flipExtraRotation>10</flipExtraRotation> 
		</graphicData>
		<size>(1,1)</size>
		<leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
		<killedLeavings>
			<ChunkLimestone>1</ChunkLimestone>
		</killedLeavings>
		<costList>
			<ChunkLimestone>2</ChunkLimestone>
		</costList>
	</ThingDef>
</Defs>

